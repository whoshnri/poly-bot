# ─── Telegram ────────────────────────────────────────────────────────────────
# Required. Get your token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# Optional but recommended. Any random string — pass the same value to
# Telegram's setWebhook `secret_token` field so only Telegram can call your
# webhook endpoint.
TELEGRAM_WEBHOOK_SECRET=

# ─── AI / Gemini ─────────────────────────────────────────────────────────────
# Required for the agent graph. Get an API key at https://aistudio.google.com
GEMINI_API_KEY=

# ─── Database ────────────────────────────────────────────────────────────────
# Required. PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=

# ─── Internal API security ───────────────────────────────────────────────────
# Used to protect the /wake endpoint. Any secret string works.
# Leave blank in local dev to skip auth.
WAKE_API_TOKEN=

# ─── Polymarket ──────────────────────────────────────────────────────────────
# Required for live trading. Your Polymarket CLOB API credentials.
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_PRIVATE_KEY=
